<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <AssemblyName>IpatHelperNet</AssemblyName>
    <RootNamespace>IpatHelperNet</RootNamespace>
    <Version>1.0.20</Version>
    <PackageId>IpatHelperNet</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Authors>Mikimini9627</Authors>
    <Description>C# wrapper for IpatHelper native DLL (JRA I-PAT automation)</Description>
    <!-- ・ｽl・ｽC・ｽe・ｽB・ｽuDLL・ｽz・ｽu・ｽﾌ趣ｿｽ・ｽ・ｽ・ｽR・ｽs・ｽ[・ｽ・ｽL・ｽ・ｽ・ｽ・ｽ -->
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- ・ｽl・ｽC・ｽe・ｽB・ｽuDLL・ｽ・ｽNuGet・ｽp・ｽb・ｽP・ｽ[・ｽW・ｽ・ｽ runtimes ・ｽt・ｽH・ｽ・ｽ・ｽ_・ｽﾉ格・ｽ[ -->
  <ItemGroup>
    <!-- x64 Release DLL -->
    <None Include="runtimes\win-x64\native\IpatHelper.dll">
      <Pack>true</Pack>
      <PackagePath>runtimes\win-x64\native\IpatHelper.dll</PackagePath>
    </None>
    <!-- x86 Release DLL -->
    <None Include="runtimes\win-x86\native\IpatHelper.dll">
      <Pack>true</Pack>
      <PackagePath>runtimes\win-x86\native\IpatHelper.dll</PackagePath>
    </None>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
